{
    "name": "tensorbuzz/tensorbuzz-php",
    "description": "PHP client for TensorBuzz error reporting.",
    "type": "library",
    "keywords": ["tensorbuzz", "error-reporting", "bug-reporting", "exceptions", "monitoring"],
    "homepage": "https://github.com/kaspernj/tensorbuzz-php",
    "license": "MIT",
    "require": {
        "php": ">=5.6",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^5.7 || ^6.5 || ^7.5 || ^8.5 || ^9.5 || ^10.5 || ^11.5 || ^12.0",
        "squizlabs/php_codesniffer": "^3.7",
        "phpcompatibility/php-compatibility": "^9.3"
    },
    "autoload": {
        "psr-4": {
            "Tensorbuzz\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tensorbuzz\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpcs": "phpcs",
        "compat": "phpcs"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
